  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Course title is required"
          },
          {
            "rules": [
              {
                "flag": "max",
                "constraint": 100
              }
            ],
            "level": "warning",
            "message": "Keep course titles concise for better display"
          }
        ],
        "name": "title",
        "type": "string"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 96
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Slug is required for URL generation"
          }
        ],
        "name": "slug",
        "type": "slug"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Description helps students understand the course"
          },
          {
            "rules": [
              {
                "flag": "min",
                "constraint": 50
              }
            ],
            "level": "warning",
            "message": "Add more detail to help students decide"
          },
          {
            "rules": [
              {
                "flag": "max",
                "constraint": 1000
              }
            ],
            "level": "warning",
            "message": "Keep descriptions focused and scannable"
          }
        ],
        "description": "Compelling description of what students will learn",
        "name": "description",
        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Course thumbnail image (16:9 ratio recommended). If not provided, a placeholder will be shown.",
        "name": "thumbnail",
        "type": "image"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Category helps students find your course"
          }
        ],
        "description": "Primary category for this course",
        "to": [
          {
            "type": "category"
          }
        ],
        "name": "category",
        "type": "reference"
      },
      {
        "options": {
          "list": [
            {
              "title": "Free",
              "value": "free"
            },
            {
              "title": "Pro",
              "value": "pro"
            },
            {
              "title": "Ultra",
              "value": "ultra"
            }
          ],
          "layout": "radio"
        },
        "initialValue": "free",
        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "free",
                  "pro",
                  "ultra"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Select an access tier for this course"
          }
        ],
        "description": "Access tier required to view this course",
        "name": "tier",
        "type": "string"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "min",
                "constraint": 1
              }
            ],
            "level": "warning",
            "message": "Add at least one module to your course"
          }
        ],
        "description": "Course modules in order",
        "of": [
          {
            "to": [
              {
                "type": "module"
              }
            ],
            "type": "reference",
            "title": "Reference to module"
          }
        ],
